# SPDX-License-Identifier: AGPL-3.0-or-later
#
# Reference for the secrets that must be filled in deploy.yaml before
# submitting to Akash. Copy to .env (gitignored) if you want to keep them
# in a file locally; the SDL itself reads values at submit time, not from
# this file.

# 32-byte master seed for op-1's hybrid account, in 0x + 64 hex format.
# The patched faucet (faucet-deploy-testnet-akash-1) accepts this via the
# QUIP_FAUCET_HYBRID_MASTER_SEED_HEX env (or --hybrid-master-seed-hex CLI).
# It bypasses the DEV_HYBRID_SEEDS hardcoded-dev-URI check and lets the
# faucet sign as op-1 (chain sudo).
#
# Derive locally from op-1's BIP-39 phrase (Proton Pass) — same secret as
# the bootnodes deploy:
#
#   docker run --rm --entrypoint /usr/local/bin/quip-network-node \
#     registry.gitlab.com/quip.network/quip-protocol-rs/quip-network-node:v0.2-preview \
#     key inspect "<paste-mnemonic>" --output-type json \
#     | jq -r .secretSeed
#
# Paste the resulting 0x + 64-hex string into deploy.yaml.
QUIP_FAUCET_HYBRID_MASTER_SEED_HEX=

# Bearer token for faucet.testnet.quip.network minted via certifier admin.
# The v1 deploy used a token for the same hostname; if it wasn't revoked
# during the v1 teardown, it's still valid (per-domain throttle is server-
# side, not tied to the token). Otherwise mint a fresh one.
CERTIFIER_TOKEN=
